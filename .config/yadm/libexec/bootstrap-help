#!/usr/bin/env bash
# Usage: bootstrap help [subcommand]
# Summary: Show this help or help for a specific subcommand

set -e

SUBDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIBEXEC="$SUBDIR"

if [[ "$1" == "--complete" ]]; then
    exec "$SUBDIR/bootstrap-commands"
fi

show_usage() {
    cat <<'EOF'
Usage: bootstrap <subcommand> [options]

Subcommands:
  init      Install tools and setup system
  update    Update specific tools via nix
  list      List available/installed tools
  motd      Manage custom MOTD (message of the day)
  help      Show this help or help for a specific subcommand

Options:
  -h, --help  Show help for a subcommand

Examples:
  bootstrap init -m dev
  bootstrap update nvim
  bootstrap list
  bootstrap motd
  bootstrap help init

Run 'bootstrap <subcommand> --help' for subcommand-specific options.
EOF
}

SUBCMD="${1:-}"
# Skip if $1 is "help" itself (bootstrap help help -> show usage, not self-referential)
if [[ -z "$SUBCMD" || "$SUBCMD" == "help" ]]; then
    show_usage
elif [[ -f "$LIBEXEC/bootstrap-$SUBCMD" ]]; then
    echo ""
    echo "=== bootstrap $SUBCMD ==="
    echo ""
    # Extract magic comments: Usage:, Summary:, Description:
    grep -E '^# (Usage|Summary|Description)[:=]' "$LIBEXEC/bootstrap-$SUBCMD" 2>/dev/null | \
        sed 's/^# //'
    echo ""
    # Extract option lines: # --option
    grep -E '^# --' "$LIBEXEC/bootstrap-$SUBCMD" 2>/dev/null | \
        sed 's/^# --/-/'
else
    show_usage
fi