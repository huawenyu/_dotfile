#!/usr/bin/env bash
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SELF="$(basename "${BASH_SOURCE[0]}")"

find_tool_subcmd() {
    local cmd="$1"

    # 1. Check for Flat+Dir layout: me-tool-<cmd>/_main_ in local dir
    local local_path="$DIR/${SELF}-${cmd}"
    if [[ -d "$local_path" && -x "$local_path/_main_" ]]; then
        echo "$local_path/_main_"; return 0
    elif [[ -x "$local_path" ]]; then
        echo "$local_path"; return 0
    fi

    # 2. Check tool/ directory for me-<cmd> files
    local tool_dir="/home/hyu/dotwiki/tool"
    if [[ -d "$tool_dir" ]]; then
        # Flat+Dir: tool/me-<cmd>/_main_ or tool/me-<cmd>
        local me_file="$tool_dir/me-${cmd}"
        if [[ -d "$me_file" && -x "$me_file/_main_" ]]; then
            echo "$me_file/_main_"; return 0
        elif [[ -x "$me_file" ]]; then
            echo "$me_file"; return 0
        fi
    fi
    return 1
}

list_tool_subcmds() {
    local tool_dir="/home/hyu/dotwiki/tool"
    [[ ! -d "$tool_dir" ]] && return

    # Subcommands already available via other me subcommands - skip these
    local skip_cmds="ai-log config-dut config-gitvan fgt-addr2line fgt-craddr fgt-eco fgt-pcap sshfs sync trace update-repo update-wiki"

    {
        # Scan tool/ for me-<name> files (Flat layout: me-sync, me-sshfs)
        for f in "$tool_dir/me-"*; do
            if [[ -x "$f" && ! -d "$f" ]]; then
                local name="$(basename "$f" | sed 's/^me-//')"
                # Skip if already a me subcommand or has a parent me subcommand
                if [[ " $skip_cmds " == *" $name "* ]]; then
                    continue
                fi
                echo "$name"
            elif [[ -d "$f" && -x "$f/_main_" ]]; then
                local name="$(basename "$f" | sed 's/^me-//')"
                if [[ " $skip_cmds " == *" $name "* ]]; then
                    continue
                fi
                echo "$name"
            fi
        done 2>/dev/null
    } | sort -u
}

cmd="${1:-help}"

case "$cmd" in
    --summary)
        echo "Tool subcommands"
        exit 0 ;;
    __commands)
        list_tool_subcmds
        exit 0 ;;
    __complete)
        shift || true
        p="$(find_tool_subcmd "${1:-}")" && "$p" __complete "" 2>/dev/null
        [[ -z "${1:-}" ]] && list_tool_subcmds
        exit 0 ;;
    __help)
        shift || true
        p="$(find_tool_subcmd "${1:-}")" && "$p" --summary 2>/dev/null
        exit 0 ;;
    help|-h|--help)
        sub="${2:-}"
        if [[ -n "$sub" && "$sub" != "help" ]]; then
            p="$(find_tool_subcmd "$sub")" && exec "$p" --help
            echo "$SELF: unknown command '$sub'" >&2; exit 1
        fi
        echo "Usage: $SELF <subcommand> [options]"; echo; echo "Subcommands:"; echo
        for sub in $(list_tool_subcmds); do
            p="$(find_tool_subcmd "$sub")"
            s="$("$p" --summary 2>/dev/null || true)"
            printf "  %-15s %s\n" "$sub" "$s"
        done | sort
        echo; echo "Run '$SELF help <subcommand>' for details."; echo
        echo "Script: ${BASH_SOURCE[0]}"; exit 0 ;;
esac

shift || true
p="$(find_tool_subcmd "$cmd")"
if [[ -n "$p" ]]; then
    exec "$p" "$@"
fi
echo "$SELF: unknown command '$cmd'" >&2
echo "Run '$SELF --help' for usage." >&2
exit 1
