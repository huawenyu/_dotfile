#!/usr/bin/env python3
"""
Usage:
    clangme.py -a macro --file filename.c
    clangme.py --file stats_def.c

If compile_commands.json exists in cwd (or a parent), uses jq to find the
exact compile command for the target file, then replaces -c/-o with -E -P
for preprocessing. Otherwise, runs clang with minimal flags (no -I paths).
"""

import os
import sys
import json
import shlex
import shutil
import argparse
import subprocess
from pathlib import Path

__version__ = "0.2.0.dev0"


def is_tool_available(name):
    return shutil.which(name) is not None


# ==================== compile_commands.json path ====================

def find_compile_db(start_dir="."):
    """Search for compile_commands.json in cwd and parent directories."""
    current = Path(start_dir).resolve()
    while True:
        candidate = current / "compile_commands.json"
        if candidate.exists():
            return str(candidate)
        if current.parent == current:
            break
        current = current.parent
    return None


# ==================== jq-based entry lookup ====================

def find_compile_entry_via_jq(json_file, target_file):
    """Use jq to find a compile entry matching target_file.

    For .c files: matches by basename.
    For .h files: no compile_commands.json entry exists, so find a .c file
    in the same directory and use its compile flags.
    Returns the JSON entry dict or None.
    """
    target_path = Path(target_file)
    target_basename = target_path.name

    # Direct match by basename (works for .c files)
    jq_filter = f'[.[] | select(.file | endswith("{target_basename}"))][0]'
    cmd = ["jq", "-c", jq_filter, json_file]
    result = subprocess.run(cmd, capture_output=True, text=True)

    if result.returncode == 0:
        output = result.stdout.strip()
        if output and output != "null":
            try:
                return json.loads(output)
            except json.JSONDecodeError:
                pass

    # For .h files: find a .c file with the same basename (wad_stats_def.h → wad_stats_def.c)
    if target_path.suffix in ('.h', '.hpp'):
        stem = target_path.stem  # e.g. "wad_stats_def"
        jq_filter_h = f'[.[] | select(.file | endswith("/{stem}.c"))][0]'
        cmd = ["jq", "-c", jq_filter_h, json_file]
        result = subprocess.run(cmd, capture_output=True, text=True)

        if result.returncode == 0:
            output = result.stdout.strip()
            if output and output != "null":
                try:
                    entry = json.loads(output)
                    print(f"  [info] Header {target_basename} not in compile_commands.json, "
                          f"using sibling: {Path(entry.get('file', '')).name}")
                    return entry
                except json.JSONDecodeError:
                    pass

    return None


# ==================== command transformation ====================

def transform_command_for_macro(args, out_file, clang_path="clang", dump_defines=False):
    """Transform compile args into preprocess args.

    - Replace compiler with clang_path
    - Remove -c (implied by -E)
    - Remove -o <old_output> (replaced with -o <out_file>)
    - Drop GCC-specific flags clang doesn't understand
    - Keep all -I, -D, -U, -std= flags and the source file
    - Add -E -CC at the end (no -P: keep line markers for filtering)
    """
    # Flags clang doesn't support (from GCC-only compile_commands.json)
    DROP_FLAGS = {
        "-fno-reorder-functions",
        "-fno-unit-at-a-time",
        "-Wtrampolines",
    }

    result = [clang_path, "-I."]
    skip_next = False

    for i in range(1, len(args)):
        if skip_next:
            skip_next = False
            continue

        arg = args[i]

        if arg == "-c":
            continue
        elif arg == "-o":
            skip_next = True
            continue
        elif arg in DROP_FLAGS:
            continue
        else:
            result.append(arg)

    flags = ["-E", "-CC", "-Wno-error=macro-redefined"]
    if dump_defines:
        flags.append("-dD")
    flags.extend(["-o", out_file])
    result.extend(flags)
    return result


def remap_entry_paths(args, old_dir, new_base, target_file):
    """Remap absolute paths from old_dir to new_base, and replace source file.

    - Absolute paths starting with old_dir get rebased to new_base.
    - -I<old_dir>/... (concatenated form) also gets rebased.
    - /src/... paths also get rebased to new_base.
    - Relative paths (e.g. -I./foo) are left as-is (resolve against new cwd).
    - The source file arg is replaced with the user's --file absolute path.
    - Flags consuming a value (-o, -MF, -MT, -MQ, -include) preserve next arg.
    """
    old_dir = str(Path(old_dir).resolve())
    new_base = str(Path(new_base).resolve())
    abs_target = str(Path(target_file).resolve())

    def remap_path(p):
        """Rebase absolute path from old_dir or /src to new_base."""
        if p.startswith(old_dir + "/"):
            return new_base + p[len(old_dir):]
        if p.startswith("/src/"):
            return new_base + p[len("/src"):]
        return p

    result = []
    skip_next = False
    for i in range(1, len(args)):
        if skip_next:
            val = args[i]
            if result and result[-1] == "-include" and val.startswith("/"):
                val = remap_path(val)
            result.append(val)
            skip_next = False
            continue
        arg = args[i]
        if arg in ("-o", "-MF", "-MT", "-MQ", "-include"):
            skip_next = True
            result.append(arg)
            continue
        # -I<abs_path> (concatenated form)
        if arg.startswith("-I") and not arg.startswith("-I" + "."):
            remapped = remap_path(arg[2:])
            if remapped != arg[2:]:
                arg = "-I" + remapped
        # standalone absolute path
        elif arg.startswith(old_dir + "/"):
            arg = remap_path(arg)
        # source file arg (not a flag, has .c/.cc/.cpp/.cxx suffix) -> user's --file
        elif not arg.startswith("-") and Path(arg).suffix in (".c", ".cc", ".cpp", ".cxx"):
            arg = abs_target
        result.append(arg)
    return result


# ==================== output filtering ====================

import re

_MARKER_RE = re.compile(r'^# \d+ "([^"]+)"')


def filter_preprocessor_output(out_file, keep_patterns):
    """Filter preprocessed output using line markers.

    Keeps only lines from files whose basename contains any of keep_patterns.
    Strips line markers, replaces with section comments for readability.
    Collapses consecutive blank lines.
    """
    with open(out_file, 'r') as f:
        lines = f.readlines()

    result = []
    keep = False
    prev_blank = False
    last_file = None

    for line in lines:
        m = _MARKER_RE.match(line)
        if m:
            current_file = m.group(1)
            basename = os.path.basename(current_file)
            new_keep = any(p in basename for p in keep_patterns)

            if new_keep and current_file != last_file:
                if result and not prev_blank:
                    result.append('\n')
                result.append(f'// === {basename} ===\n')
                prev_blank = False

            keep = new_keep
            last_file = current_file
            continue

        if not keep:
            continue

        is_blank = line.strip() == ''
        if is_blank and prev_blank:
            continue
        prev_blank = is_blank

        result.append(line)

    with open(out_file, 'w') as f:
        f.writelines(result)

    return len(lines), len(result)


def split_long_lines(out_file, threshold=200):
    """Break long lines at ; { } with brace-depth indentation.

    Splits at each brace and semicolon (not inside strings), tracks nesting
    to indent each piece correctly.
    """
    with open(out_file, 'r') as f:
        lines = f.readlines()

    result = []
    for line in lines:
        if len(line) <= threshold:
            result.append(line)
            continue

        depth = 0
        in_string = False
        escape = False
        current = []
        init_depths = set()  # depths that are initializers (= { ... })

        for ch in line.rstrip('\n'):
            if escape:
                escape = False
                current.append(ch)
                continue
            if ch == '\\':
                escape = True
                current.append(ch)
                continue
            if ch == '"':
                in_string = not in_string
                current.append(ch)
                continue
            if in_string:
                current.append(ch)
                continue

            if ch == '{':
                frag = ''.join(current).strip()
                # Don't split initializers like "= { 0 }" — keep on one line
                if frag.endswith('='):
                    current.append(ch)
                    depth += 1
                    init_depths.add(depth)
                    continue
                if frag:
                    # K&R style: put { on same line as preceding code when short
                    if len(frag) <= 120:
                        result.append('    ' * depth + frag + ' {\n')
                    else:
                        result.append('    ' * depth + frag + '\n')
                        result.append('    ' * depth + '{\n')
                else:
                    result.append('    ' * depth + '{\n')
                depth += 1
                current = []
            elif ch == '}':
                frag = ''.join(current).strip()
                if depth in init_depths:
                    # Initializer close: merge content onto one line
                    result.append('    ' * (depth - 1) + frag + ' }\n')
                    init_depths.discard(depth)
                    depth -= 1
                    current = []
                else:
                    if frag:
                        result.append('    ' * depth + frag + ';\n')
                    depth = max(0, depth - 1)
                    result.append('    ' * depth + '}\n')
                current = []
            elif ch == ';':
                frag = ''.join(current).strip()
                if frag:
                    if depth in init_depths:
                        # Inside initializer: no semicolon (will be added at })
                        result.append('    ' * depth + frag + '\n')
                    else:
                        result.append('    ' * depth + frag + ';\n')
                current = []
            else:
                current.append(ch)

        if current:
            tail = ''.join(current).strip()
            if tail:
                # If still very long with commas (array initializers), split at commas
                if len(tail) > threshold and ',' in tail:
                    comma_parts = tail.split(',')
                    for i, cp in enumerate(comma_parts):
                        cp = cp.strip().rstrip(';')
                        if not cp:
                            continue
                        suffix = ',' if i < len(comma_parts) - 1 else ';'
                        result.append('    ' * depth + cp + suffix + '\n')
                else:
                    result.append('    ' * depth + tail + ';\n')

    with open(out_file, 'w') as f:
        f.writelines(result)

    return len(lines), len(result)


# ==================== main runner ====================

def run_clang_for_file(compile_db, target_file, out_file, clang_path="clang", dump_defines=False):
    """Run clang to preprocess target_file.

    If compile_db exists and contains the target file, uses the compile
    command from it (with -c/-o replaced by -E -P).
    Otherwise, runs clang with minimal flags.
    """
    if compile_db and os.path.exists(compile_db):
        entry = find_compile_entry_via_jq(compile_db, target_file)
        if entry:
            # Get args from command string or arguments array
            if "command" in entry:
                args = shlex.split(entry["command"])
            elif "arguments" in entry:
                args = list(entry["arguments"])
            else:
                print(f"Warning: entry has no command or arguments, using fallback")
                args = None

            if args:
                old_dir = entry.get("directory", ".")
                new_base = str(Path(compile_db).resolve().parent)

                if Path(old_dir).resolve() != Path(new_base).resolve():
                    print(f"Remapping paths: {old_dir} -> {new_base}")
                    args = remap_entry_paths(args, old_dir, new_base, target_file)
                    directory = new_base
                else:
                    directory = old_dir

                command = transform_command_for_macro(args, out_file, clang_path,
                                                       dump_defines)
                print(f"Using compile_commands.json: {compile_db}")
                print(f"  cwd: {directory}")
                print(f"  cmd: {' '.join(command)}")
                subprocess.run(command, cwd=directory, check=True)
                return
        else:
            print(f"Warning: {Path(target_file).name} not found in {compile_db}, using fallback")

    # Fallback: minimal flags, no -I paths
    command = [clang_path, "-E", "-CC", "-std=gnu11", "-I.", "-o", out_file, target_file]
    print("Running (no compile_commands.json):")
    print(f"  cmd: {' '.join(command)}")
    subprocess.run(command, check=True)


# ==================== formatting ====================

def clang_safe_format(file_path, config_path):
    """Format file with clang-format."""
    try:
        if os.path.exists(config_path):
            subprocess.run(
                ["clang-format", "-i", f"--style=file:{config_path}",
                 "--assume-filename=log.c", file_path],
                check=True,
            )
        else:
            subprocess.run(
                ["clang-format", "-i", "--style=file",
                 "--assume-filename=log.c", file_path],
                check=True,
            )
    except FileNotFoundError:
        print("clang-format executable not found")
        print("Install clang tools:")
        print("  nix-env -iA nixpkgs.clang-format")
    except subprocess.CalledProcessError as e:
        print(f"clang-format failed with exit code {e.returncode}")
        if e.stderr:
            print(f"Error: {e.stderr}")


# ==================== CLI ====================

def main():
    if '--summary' in sys.argv:
        print("Preprocess C files using clang via compile_commands.json")
        sys.exit(0)
    if '--complete' in sys.argv or '__complete' in sys.argv:
        for c in ['--help', '--summary', '--complete', '__complete', '--verbose', '--file', '--config', '--action', '--out', '--compile-db']:
            print(c)
        sys.exit(0)

    parser = argparse.ArgumentParser(
        description="Preprocess C files using clang via compile_commands.json",
        epilog="Example:\n  me clang ./migbase/sysapi/wad/wad_stats_def.c\n  me clang --action macro --file ./migbase/sysapi/wad/wad_stats_def.c\n\nScript: /home/hyu/script/me-clang",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    parser.add_argument('--verbose', action='store_true')
    parser.add_argument('positional_file', nargs='?', default=None,
                        help='Input file (shorthand for --file)')
    parser.add_argument('--file', dest='file', default=None,
                        help='Input file (alternative to positional argument)')
    parser.add_argument('--config', default='.clang-format',
                        help='Configuration file for clang-format')
    parser.add_argument('--action', '-a', default='macro',
                        choices=['macro', 'compile', 'default'],
                        help='The action of clang (default: macro)')
    parser.add_argument('--out', default='log.i',
                        help='Output file (default: log.i)')
    parser.add_argument('--compile-db', default=None,
                        help='Path to compile_commands.json (auto-detected if omitted)')
    parser.add_argument('--no-filter', action='store_true',
                        help='Disable output filtering (keep all included headers)')
    parser.add_argument('--clang-format', action='store_true',
                        help='Use clang-format instead of fast line-splitter (slow on generated code)')
    parser.add_argument('--dump-defines', action='store_true',
                        help='Preserve #define directives (-dD flag)')
    parser.add_argument('--keep-pattern', default=None,
                        help='Comma-separated basename patterns to keep (default: wad_stats,shm_stats)')
    args = parser.parse_args()

    # Resolve file: positional arg takes priority, then --file
    args.file = args.positional_file or args.file
    if not args.file:
        parser.error("the following arguments are required: file (positional or --file)")

    # Find compile_commands.json
    compile_db = args.compile_db
    if compile_db is None:
        compile_db = find_compile_db()

    clang_path = "clang"

    try:
        run_clang_for_file(compile_db, args.file, args.out, clang_path,
                           dump_defines=args.dump_defines)

        if args.verbose and os.path.exists(args.out):
            import subprocess as _sp
            r = _sp.run(['wc', '-l', args.out], capture_output=True, text=True)
            print(f"  [debug] After clang: {r.stdout.strip()}")

        if os.path.exists(args.out) and not args.no_filter:
            patterns = args.keep_pattern.split(',') if args.keep_pattern else ['wad_stats', 'shm_stats']
            total, kept = filter_preprocessor_output(args.out, patterns)
            print(f"Filtered: {total} -> {kept} lines (keeping: {', '.join(patterns)})")

        if args.verbose and os.path.exists(args.out):
            import subprocess as _sp
            r = _sp.run(['wc', '-l', args.out], capture_output=True, text=True)
            print(f"  [debug] After filter: {r.stdout.strip()}")

        if os.path.exists(args.out):
            if args.clang_format:
                print(f"===\nFormatting '{args.out}' with clang-format, please wait ...\n")
                clang_safe_format(args.out, args.config)
            else:
                total, kept = split_long_lines(args.out)
                print(f"Split long lines: {total} -> {kept} lines")

            # Append vim modeline for filetype detection
            with open(args.out, 'a') as f:
                f.write('\n/* vim: set ft=c : */\n')

        if args.verbose and os.path.exists(args.out):
            import subprocess as _sp
            r = _sp.run(['wc', '-l', args.out], capture_output=True, text=True)
            print(f"  [debug] Final: {r.stdout.strip()}")
    except subprocess.CalledProcessError as e:
        print(f"Error: command failed with exit code {e.returncode}")
        sys.exit(1)


if __name__ == "__main__":
    main()
